# SQL Server Connection Configuration

# Basic connection settings
SERVER_NAME=localhost
DATABASE_NAME=your_database_name

# Connection options
TRUST_SERVER_CERTIFICATE=true
CONNECTION_TIMEOUT=30
ENCRYPT=false
READONLY=false

# Authentication Method Selection
# Set USE_WINDOWS_AUTH=true for Windows Authentication
# Set USE_WINDOWS_AUTH=false (or omit) for SQL Server Authentication
USE_WINDOWS_AUTH=false

# ===============================================
# SQL Server Authentication (when USE_WINDOWS_AUTH=false)
# ===============================================
USERNAME=your_sql_username
PASSWORD=your_sql_password

# ===============================================
# Windows Authentication (when USE_WINDOWS_AUTH=true)
# ===============================================
# For Windows Authentication, you can specify:
# DOMAIN=your_domain_name     # Optional: specify domain (leave empty for local machine)
# USERNAME=your_windows_user  # Optional: specify user (leave empty to use current user)
# PASSWORD=your_windows_pass  # Optional: specify password (leave empty for current user)

# Examples for Windows Authentication:

# Example 1: Use current Windows user (recommended for local development)
# USE_WINDOWS_AUTH=true
# DOMAIN=
# USERNAME=
# PASSWORD=

# Example 2: Use specific domain user
# USE_WINDOWS_AUTH=true
# DOMAIN=MYDOMAIN
# USERNAME=myuser
# PASSWORD=mypassword

# Example 3: Use local Windows user
# USE_WINDOWS_AUTH=true
# DOMAIN=
# USERNAME=localuser
# PASSWORD=localpassword
